{
  "_comment": "Auto-generated by /cloudwatch configure. Edit as needed.",
  "aws_cli": "aws",
  "region": "us-east-1",
  "account_id": "123456789012",
  "output_dir": "logs/",
  "default_log_group": "/ecs/my-app-production",
  "log_groups": [
    {
      "name": "/ecs/my-app-production",
      "category": "ecs-app",
      "purpose": "Backend application logs",
      "priority": 1,
      "retention_days": 7,
      "stored_bytes": 524288000
    },
    {
      "name": "/ecs/my-app-production-frontend",
      "category": "ecs-frontend",
      "purpose": "Frontend application logs",
      "priority": 2,
      "retention_days": 7,
      "stored_bytes": 104857600
    },
    {
      "name": "/aws/rds/cluster/my-app-production-cluster/postgresql",
      "category": "rds",
      "purpose": "Database logs",
      "priority": 3,
      "retention_days": 14,
      "stored_bytes": 209715200
    },
    {
      "name": "aws-waf-logs-my-app-production",
      "category": "waf",
      "purpose": "WAF request logs (blocked requests, rate limiting)",
      "priority": 4,
      "retention_days": 30,
      "stored_bytes": 52428800
    },
    {
      "name": "/aws/ecs/containerinsights/my-app-cluster/performance",
      "category": "container-insights",
      "purpose": "ECS Container Insights (CPU, memory, task crashes)",
      "priority": 5,
      "retention_days": 7,
      "stored_bytes": 10485760
    },
    {
      "name": "/aws/vpc/my-app-production",
      "category": "vpc",
      "purpose": "VPC flow logs (network issues)",
      "priority": 6,
      "retention_days": 7,
      "stored_bytes": 1048576000
    }
  ],
  "ecs": [
    {
      "cluster": "my-app-production-cluster",
      "services": [
        "arn:aws:ecs:us-east-1:123456789012:service/my-app-production-cluster/my-app-web",
        "arn:aws:ecs:us-east-1:123456789012:service/my-app-production-cluster/my-app-worker"
      ]
    }
  ],
  "alarms": [
    {
      "name": "my-app-ApplicationErrors-High",
      "metric": "ErrorCount",
      "namespace": "AWS/ApplicationELB",
      "threshold": 50,
      "state": "OK"
    },
    {
      "name": "my-app-ECS-CPU-High",
      "metric": "CPUUtilization",
      "namespace": "AWS/ECS",
      "threshold": 80,
      "state": "OK"
    }
  ]
}
